# Contact form — Web3Forms (free, client-side submission)
# 1. Go to https://web3forms.com and create an Access Key for your email
# 2. Paste the key below
# 3. Rename this file to ".env.local" (then restart `npm run dev`)
#
# NOTE: This key is exposed in the browser by design — Web3Forms keys are
# public. Spam is mitigated by the honeypot field + the Web3Forms dashboard.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here
